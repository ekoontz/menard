 "avere"
 (let [exceptions {:future-stem "avr"
                   :drop-e true
                   :present {:1sing "ho"
                             :2sing "hai"
                             :3sing "ha"
                             :1plur "abbiamo"
                             :2plur "avete"
                             :3plur "hanno"}}]
   ;; 1. "avere": to possess something buyable
   [{:exceptions exceptions
     :note "avere (possess)"
     :synsem {:sem {:pred :have}}}

    ;; 2. "avere": to be in a familial or social relation with:
    ;; e.g. "ho due bambini (I have two children)"
    {:exceptions exceptions
     :note "avere (relation)"
     :synsem {:sem {:pred :have}}}

    ;; 3. avere: unspecified object
    ;; TODO: remove: should be generated automatically via
    ;; intransitivization
    ;;
    {:exceptions exceptions
     :note "avere (possess): unspecified object"
     :sem {:pred :have}}

    ;; 4. passato transitive
    (let [agr (atom :top)]
      {:exceptions exceptions
       :note "passato prossimo transitive"
       :aux? true
       :transitive? true
       :sem {:tense :present
             :aspect :perfect}
       :subcat {:2 {:agr agr
                    :cat :verb
                    :reflexive? false
                    :transitive? true
                    :subcat {:2 {:agr agr
                                 :pronoun true}}
                    :essere? false}}})

    ;; 5. passato prossimo intransitive
    {:exceptions exceptions
     :note "passato prossimo intransitive"
     :aux? true
     :infl :present
     :sem {:tense :present
           :aspect :perfect}
     :subcat {:2 {:reflexive? false
                  :essere? false
                  :infl :passato
                  :cat :verb
                  ;; in Italian, reflexive verbs are always essere=true.
                  ;; this additional qualification here (:reflexive false) is not necessary
                  ;; but is expected to speed up generation.
                  :subcat {:2 []}}}}

    ;; 6. trapassato intransitive
    {:exceptions exceptions
     :note "trapassato intransitive"
     :aux? true
     :infl :imperfetto
     :sem {:tense :past
           :aspect :pluperfect}
     :subcat {:2 {:reflexive? false
                  :infl :passato
                  :cat :verb
                  :essere false
                  ;; in Italian, reflexive verbs are always essere=true.
                  ;; this additional qualification here (:reflexive false) is not necessary
                  ;; but is expected to speed up generation
                  :subcat {:2 []}}}}

    ;; TODO: add trapassato transitive
    ;; TODO: add avere bisogno di X => need X
    ])

