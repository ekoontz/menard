 "chiamarsi" (let [gender (atom :top)
                   human (atom :top)
                   number (atom :top)
                   name-semantics {:human human}]
               [
                ;; Lei si chiama Luisa.
                {:sem {:pred :be-called
                       :iobj name-semantics}
                 :subcat {:1 {:agr {:gender gender
                                    :number number}
                              :sem {:human human}
                              :propernoun? false} ;; avoid e.g. "Luisa si chiama Luisa".
                          :3 {:agr {:gender gender
                                    :number number}
                              :cat :noun
                              :sem name-semantics
                              :propernoun? true}}}

                ;; Si chiama Luisa.
                {:sem {:pred :be-called
                       :iobj name-semantics}
                 :subcat {:1 {:pronoun? true
                              :cat :noun
                              :case :acc
                              :reflexive? true}
                          :2 {:agr {:gender gender
                                    :number number}
                              :cat :noun
                              :sem name-semantics
                              :propernoun? true}}}])

