                   :future {:1sing "sarò"
                            :2sing "sarai"
                            :3sing "sarà"
                            :1plur "saremo"
                            :2plur "sarete"
                            :3plur "saranno"}
                   :conditional {:1sing "sarei"
                                 :2sing "saresti"
                                 :3sing "sarebbe"
                                 :1plur "saremmo"
                                 :2plur "sareste"
                                 :3plur "sarebbero"}}]
   [{:exceptions exceptions
     :notes "to-be"
     :essere? true
     :sem {:pred :be}}

    {:exceptions exceptions
     :notes "essere-aux-passato"
     :essere? true
     :aux? true
     :infl :present
     :sem {:tense :present
